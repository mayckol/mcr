{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MCR",
  "version": "0.3.0",
  "identifier": "dev.mcr.mergeeditor",
  "build": {
    "frontendDist": "../ui/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm --prefix ui run dev",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "title": "MCR — Merge Editor",
        "width": 1400,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "DeveloperTool",
    "shortDescription": "Three-pane visual merge editor",
    "longDescription": "MCR — a three-pane visual git merge editor to trace, apply, and revert changes.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
